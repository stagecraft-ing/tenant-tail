# Enforce LF line endings for all text files in this repository.
# This prevents "LF will be replaced by CRLF" warnings on Windows
# and ensures consistent line endings across all platforms.

# Default: normalize all text files to LF on commit
* text=auto eol=lf

# --- Source code ---
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.vue       text eol=lf

# --- Config / markup ---
*.json      text eol=lf
*.jsonc     text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.xml       text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.scss      text eol=lf

# --- Docs ---
*.md        text eol=lf
*.mdx       text eol=lf
*.txt       text eol=lf

# --- Shell / config ---
*.sh        text eol=lf
*.conf      text eol=lf
*.env       text eol=lf
.env*       text eol=lf
Dockerfile* text eol=lf
*.dockerfile text eol=lf
.gitignore  text eol=lf
.gitattributes text eol=lf
.eslintrc*  text eol=lf
.prettierrc* text eol=lf

# --- Binary: never touch line endings ---
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.webp      binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.otf       binary
*.pdf       binary
*.zip       binary
*.gz        binary
*.tar       binary
*.tgz       binary

# --- Derived-artifact merge driver ---
# The committed derived artifacts (spec-spine 0.5.0 shards them into per-spec /
# per-package JSON files under .derived/) each carry a content hash, so two
# branches that both regenerated them conflict textually. The
# `tenant-tail-derived-regen` driver regenerates them from the merged tree (via
# the pinned spec-spine governing binary) instead of leaving conflict markers.
# Opt-in: register the driver per-clone with `./.githooks/enable-merge-driver.sh`.
# If unregistered, git falls back to the default text merge; no behavior change.
# build-meta.json is gitignored (never committed), so the glob never touches it.
.derived/**/*.json merge=tenant-tail-derived-regen
